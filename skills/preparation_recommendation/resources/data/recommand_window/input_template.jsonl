{
  "目标材料": { // 取 similar.jsonl 里的"目标材料"字段
    "化学式": "",         
    "结构原型": "",     
    "是否二维": true,           
    "是否半导体": true,         
    "材料族系": [ ]         
  },

  "相似材料检索结果": { 
    "相似材料列表": [ ] // 取 similar.jsonl 里的"相似材料列表"字段
  },

  "实验室约束": { // 由该文件设置（参数化）
    "最高允许温度_摄氏": 1000,          // 炉子封顶温度
    "最小降温速率_℃每小时": 0.5,        // 设备能稳定控制的下限
    "最大降温速率_℃每小时": 300,       // 上限
    "最长单次实验时长_h": 200           // 超过就提示“太久”
  },

  "窗口计算设置": { // 由该文件设置（参数化）
    "最小有效样本数": 1,               // 少于这个就不进行统计
    "分位数范围": [10, 90],            // 用 P10-P90 当窗口
    "异常值过滤": {
      "启用": true,
      "方法": "zscore", // 可调，还可选分位数裁剪
      "阈值": 2.5
    }
  }
}