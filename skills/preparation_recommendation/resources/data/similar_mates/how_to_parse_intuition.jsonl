{
  "目标材料": {
    "化学式": "MoS2",            // 必填：化学锚点，纯字符无空格（如MoS2、CsPbBr3、YMn2Si2），LLM直接提取知识库内容
    "结构原型": "MoS2-type",     // 必填：微观结构特征，取晶体学标准命名（如Perovskite-type、Spinel-type、MoS2-type），无则为null
    "是否二维": true,            // 必填：LLM直接提取知识库内容
    "是否半导体": true           // 必填：LLM直接提取知识库内容
  },
  "实验目标": "采用助熔剂法（flux）制备MoS2单晶",  // 可选，默认""：研究/制备目标，LLM提取原文核心动作+对象，保留关键方法（如flux/助熔剂法、气相沉积、水热）
  "检索过滤条件": {
    "只看助熔剂法": true,       // 布尔值，默认true：制备方法粗筛，仅匹配助熔剂法相关研究，false则不限制
    "只看二维材料": true,       // 布尔值，如果目标材料是二维，设置为true，否则false：结构维度粗筛，仅匹配二维材料，false则不限制，null则跳过过滤
    "只看半导体": true         // 布尔值，如果目标材料是半导体，设置为true，否则false：核心物性粗筛，仅匹配半导体，false则不限制，null则跳过过滤
  },
  "相似度设置": {
    "结构原型_权重": 0.4,     // 浮点型，默认0.4
    "是否二维_权重": 0.1,     // 浮点型，默认0.1
    "是否半导体_权重": 0.1,   // 浮点型，默认0.1
    "材料族系_权重": 0.4     // 浮点型，默认0.4（检索时自动推断，无需LLM生成）
  },
  "返回设置": {
    "最多返回材料数_top_k": 30   // top-K 材料，默认 30
  }
}
