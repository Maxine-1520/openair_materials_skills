# LLM API Configuration (OpenAI-compatible format)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=your_base_url_here
LLM_MODEL=your_model_here

# Alternative: OpenAI Official API
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Alternative: Other OpenAI-compatible APIs (Ollama, vLLM, etc.)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# Alternative: MatAI API
# LLM_BASE_URL=http://your-matai-server:port/v1
# LLM_MODEL=matai-model

# Logging Configuration
LOG_LEVEL=INFO

# Data Directory
DATA_DIR=./data

# Cache Configuration
USE_CACHE=0
